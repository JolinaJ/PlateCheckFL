{
  "manifest_version": 3,
  "name": "PlateCheck",
  "version": "0.1.1",
  "description": "Restaurant inspection information from official public records (Florida DBPR, NYC DOHMH), inline on Google Search results.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/search*",
        "https://www.google.com/search?*"
      ],
      "js": ["src/content/index.ts"]
    }
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "permissions": [],
  "host_permissions": [
    "https://www.myfloridalicense.com/*"
  ]
}
